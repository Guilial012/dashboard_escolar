# ─────────────────────────────────────────────────────────────────
# Configuração do Google Calendar
# ─────────────────────────────────────────────────────────────────

# Obtenha em https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=seu_client_id_aqui.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu_client_secret_aqui

# URI de redirecionamento (deve estar cadastrado no Google Cloud Console)
REDIRECT_URI=http://localhost:3000/auth/callback

# Gerado automaticamente ao acessar /auth/login pela primeira vez
# Após autorizar, cole o token aqui e reinicie o servidor
GOOGLE_REFRESH_TOKEN=

# Porta do servidor (opcional, padrão: 3000)
PORT=3000
